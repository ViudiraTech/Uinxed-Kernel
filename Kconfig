mainmenu "Uinxed"

menu "Kernel debugging"

  config KERNEL_LOG
    bool "Kernel debug logging output"
    default y
    help
      "Outputs kernel debug messages when running."

  config SCHED_DEBUG_DEMO
    bool "Scheduler debug demo threads"
    default n
    help
      "Creates kernel threads that exercise preemption, sleep, wait queues, SMP placement, migration, and balancing."

endmenu

menu "Processor configuration"
  menu "SMP (Symmetric multi-processing)"

    config CPU_MAX_COUNT
      int "Maximum number of CPUs"
      default 0
      help
        "Limits the maximum number of CPUs the kernel can use, set to 0 for no limit."

  endmenu
  menu "Extended instruction set"

    config CPU_FEATURE_FPU
      bool "Enable X87FPU (Intel 80X87 Floating-Point Unit)"
      default y
      help
        "Set whether to enable X87FPU/MMX."

    config CPU_FEATURE_SSE
      depends on CPU_FEATURE_FPU
      bool "Enable SSE/SSE2 (Streaming SIMD Extensions)"
      default y
      help
        "Set whether to enable SSE/SSE2."

    config CPU_FEATURE_AVX
      depends on CPU_FEATURE_SSE
      bool "Enable AVX/AVX2 (Advanced Vector Extensions)"
      default y
      help
        "Set whether to enable AVX/AVX2."

  endmenu
endmenu

menu "Device drivers"
  menu "Character devices"
    menu "Teletype devices"

      config TTY_DEFAULT_DEV
        string "Default teletype device"
        default "tty0"
        help
          "Specifies the default teletype device used when no device is explicitly set by boot parameters."

      config TTY_BUF_SIZE
        int "Teletype buffer size"
        default 4096
        range 256 16384
        help
          "Buffer size for temporarily storing input and output data in the teletype driver."

    endmenu
    menu "Serial port devices"

      config SERIAL_BAUD_RATE
        int "Serial port baud rate"
        default 9600
        range 9600 115200
        help
          "Default baud rate used by the serial port driver."

      config SERIAL_DATA_BITS
        int "Serial port data bits"
        default 8
        range 5 8
        help
          "Number of data bits per character for the serial port device."

      config SERIAL_STOP_BITS
        int "Serial port stop bits"
        default 1
        range 1 2
        help
          "Number of stop bits per character for the serial port device."

    endmenu
  endmenu
  menu "Input device support"

    config INPUT_EVDEV
      bool "Event interface (evdev)"
      default y
      help
        "Enable the Linux-compatible evdev input event subsystem, providing
        /dev/input/eventX character devices for input event delivery."

    config INPUT_EVDEV_BUFSIZE
      int "evdev buffer size (power of 2)"
      default 256
      depends on INPUT_EVDEV
      range 64 4096
      help
        "Size of the per-client event ring buffer, must be a power of 2."

  endmenu
  menu "Graphics support"

    config DRM
      bool "Direct Rendering Manager (DRM)"
      default y
      help
        "Enable the Direct Rendering Manager (DRM) subsystem,
        providing /dev/dri/card0 for GPU device access and KMS
        (Kernel Mode Setting) support."

    config BOOT_LOGO
      bool "Boot logo"
      default y
      help
        "Displays CPU logos in the top area of the screen during kernel startup,
        The number of logos is automatically adjusted according to the detected CPU count."

  endmenu

  menu "Filesystem support"

    config SYSFS
      bool "sysfs filesystem support"
      default y
      help
        "Enable the sysfs virtual filesystem, providing a structured view
        of kernel objects, devices, buses, drivers, and classes to userspace.
        sysfs is mounted at /sys and is the foundation of the Linux device model.
        This option also enables the kobject/kset infrastructure."

    config NETLINK
      bool "Netlink socket support"
      default y
      help
        "Enable AF_NETLINK socket family for kernel-userspace communication.
        Netlink is used for uevent delivery (udev), routing, and other
        kernel services. Required for hotplug and device manager support."

    config UEVENT_HELPER
      bool "uevent helper (hotplug event delivery)"
      depends on NETLINK && SYSFS
      default y
      help
        "Broadcast kernel object events (add/remove/change/move) to
        userspace via netlink KOBJECT_UEVENT protocol. This enables
        udev or mdev to react to device hotplug events."

  endmenu

  menu "VirtIO drivers"

    config VIRTIO
      bool "VirtIO PCI transport layer"
      default y
      help
        "Enable the VirtIO PCI transport layer, providing generic
        MMIO-based capability discovery and virtqueue management
        for all virtio device drivers."

    config VIRTIO_GPU
      bool "VirtIO GPU DRM driver"
      depends on DRM && VIRTIO
      default y
      help
        "Enable the VirtIO-GPU DRM driver for paravirtualised GPU
        devices (PCI vendor 0x1af4, device 0x1050).  Provides KMS
        display pipeline, render node (/dev/dri/renderD*), and
        optional 3D acceleration via the virgl context protocol."

  endmenu
endmenu
